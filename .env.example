# ============================================================
#  Executive Assistant Platform — Environment Variables
#  Infrastructure credentials only.
#  Slack tokens and all personal settings → config/users/<name>.yaml
#  NEVER commit .env to git
# ============================================================

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Microsoft Graph (App-Only / Service Principal) ──────────
# One Azure AD app registration serves all users on this instance
AZURE_TENANT_ID=your-tenant-uuid
AZURE_CLIENT_ID=your-client-uuid
AZURE_CLIENT_SECRET=your-secret-value

# ── Storage ──────────────────────────────────────────────────
DB_PATH=./data/maelle.db
LOG_PATH=./logs

# ── Runtime ──────────────────────────────────────────────────
NODE_ENV=development

# OpenAI — for voice transcription (Whisper) and text-to-speech
OPENAI_API_KEY=your-openai-api-key-here

# WhatsApp — your Slack user ID so Maelle knows who you are on WhatsApp
WHATSAPP_OWNER_PHONE=972501234567
# Your phone number in international format without + (e.g. 972501234567 for Israel)
